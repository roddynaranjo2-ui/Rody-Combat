; Engine configuration file.
; It's best edited using the editor and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Combate Móvil 2.5D"
config/description="Juego de combate móvil 2.5D — Fase 1 BETA"
config/version="1.0.0-beta"
config/icon="res://assets/ui/icons/launcher_icon.png"
run/main_scene="res://scenes/main_menu/MainMenuScene.tscn"
boot_splash/show_image=false

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=0
window/size/window_height_override=0
window/size/mode=0
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"
window/vsync/vsync_mode=1

[rendering]

renderer/rendering_method="mobile"
textures/default_filters/anisotropic_filtering_level=2
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size.mobile=1024
anti_aliasing/quality/msaa_3d.mobile=0
anti_aliasing/quality/screen_space_aa.mobile=1
environment/glow/upscale_mode.mobile=0
environment/ssao/quality=0
environment/ssil/quality=0
environment/screen_space_reflection/roughness_quality=0
environment/volumetric_fog/use_filter=0
shader_compiler/shader_cache/enabled.mobile=true
shader_compiler/shader_cache/use_zstd_compression.mobile=true
shader_compiler/shader_cache/strip_debug.mobile=true

[physics]

3d/default_gravity=19.6
3d/default_gravity_vector=Vector3(0, -1, 0)
3d/physics_engine="JoltPhysics3D"
common/physics_ticks_per_second=60
common/max_physics_steps_per_frame=8

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=false
pointing/android/enable_long_press_as_right_click=false

[input]

